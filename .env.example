# ─── Anthropic (una sola cuenta de plataforma, compartida por todas las empresas) ──
ANTHROPIC_API_KEY=sk-ant-your_key_here
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ─── Base de datos (empieza en SQLite; migrar a Postgres antes de la 2da empresa) ──
DATABASE_URL=sqlite:///./vitabot_saas.db

# ─── Panel MAESTRO (dueño del SaaS) ────────────────────────────────────────────────
# El panel de CADA empresa usa su propio admin_token (se genera al crear la empresa
# desde el panel maestro) — esta variable es solo para el panel maestro.
MASTER_ADMIN_TOKEN=choose_a_random_secret_here

# ─── Verificación del webhook de Meta ──────────────────────────────────────────────
# Cada empresa puede traer su propio webhook_verify_token (columna en la BD); este es
# el valor de plataforma que también se acepta (útil si varias empresas comparten un
# mismo Meta App, o para pruebas).
WEBHOOK_VERIFY_TOKEN=choose_any_random_string_here

# ─── Email de plataforma (Resend) ──────────────────────────────────────────────────
# Fallback si una empresa no configura su propia API key de Resend en su panel.
EMAIL_FROM_NAME=VitaBot
RESEND_API_KEY=

# ─── Groq (transcripción de voz) y ElevenLabs (respuestas de voz) — de plataforma ──
GROQ_API_KEY=gsk_tu_key_aqui
ELEVENLABS_API_KEY=

# ─── App ────────────────────────────────────────────────────────────────────────────
MAX_HISTORY_MESSAGES=15